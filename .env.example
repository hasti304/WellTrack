# Copy to .env and fill in values. Never commit .env.

SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=
CSRF_TRUSTED_ORIGINS=

# PostgreSQL (leave DB_NAME empty to use SQLite for quick local demos)
# Render-native style (recommended in production)
DATABASE_URL=
# Legacy style (still supported as fallback)
DB_NAME=
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# --- LLM (OpenAI-compatible: OpenAI, OpenRouter, SambaNova Cloud, Cerebras) ---
# LLM_PROVIDER=openai | openrouter | sambanova | cerebras
LLM_PROVIDER=openai
# Prefer LLM_API_KEY; if empty, OPENAI_API_KEY is used (backward compatible).
LLM_API_KEY=
# Model id (required for sambanova / cerebras — copy from your provider UI).
# OpenRouter examples: openai/gpt-3.5-turbo, anthropic/claude-3-haiku, meta-llama/llama-3.1-8b-instruct:free
LLM_MODEL=
# Override base URL only if your dashboard shows a different endpoint.
LLM_API_BASE=

# --- RAG (Smart Coach grounding) ---
RAG_ENABLED=True
RAG_TOP_K=4
RAG_PERSIST_DIR=chroma_db
RAG_COLLECTION=welltrack_guidelines
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

OPENAI_API_KEY=
UNSPLASH_ACCESS_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Smart Coach: optional tuning (defaults shown in settings.py)
# SMART_COACH_MAX_HISTORY_MESSAGES=16
# SMART_COACH_RAG_CONTEXT_MAX_CHARS=10000
